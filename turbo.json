{
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"],
      "env": [
        "API_URL",
        "OPENAI_API_KEY",
        "OPENAI_VECTOR_STORE_ID",
        "HEYGEN_API_KEY",
        "AVATAR_ID",
        "VOICE_ID",
        "CONTEXT_ID"
      ]
    },
    "dev": {
      "cache": false,
      "env": [
        "API_URL",
        "OPENAI_API_KEY",
        "OPENAI_VECTOR_STORE_ID",
        "HEYGEN_API_KEY",
        "AVATAR_ID",
        "VOICE_ID",
        "CONTEXT_ID"
      ]
    },
    "lint": {
      "env": [
        "API_URL",
        "OPENAI_API_KEY",
        "OPENAI_VECTOR_STORE_ID",
        "HEYGEN_API_KEY",
        "AVATAR_ID",
        "VOICE_ID",
        "CONTEXT_ID"
      ]
    }
  }
}
